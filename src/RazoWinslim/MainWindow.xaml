<Window x:Class="RazoWinslim.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="razo-winslim" Height="600" Width="800">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid Margin="12">
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding GroupedTweaks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="{Binding Key}" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Entry.DisplayName}" FontWeight="SemiBold"/>
                                                        <TextBlock Text=" (Advanced)" Foreground="DarkRed" FontWeight="SemiBold"
                                                                   Visibility="{Binding RequiresConfirmation, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Entry.Description}" Foreground="Gray" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding ErrorMessage}" Foreground="Red"
                                                               Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>
                                                <ToggleButton Grid.Column="1" IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                              Click="OnToggleClicked" Tag="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
