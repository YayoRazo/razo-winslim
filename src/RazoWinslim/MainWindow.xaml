<Window x:Class="RazoWinslim.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="razo-winslim" Height="600" Width="800">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" Width="40" Height="20" CornerRadius="10" Background="#767676">
                            <Grid>
                                <Ellipse x:Name="Thumb" Width="16" Height="16" Fill="White"
                                         HorizontalAlignment="Left" Margin="2,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#0078D4"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <ScrollViewer Padding="0,0,12,0">
            <ItemsControl ItemsSource="{Binding GroupedTweaks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="{Binding Key}" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Entry.DisplayName}" FontWeight="SemiBold"/>
                                                        <TextBlock Text=" (Advanced)" Foreground="IndianRed" FontWeight="SemiBold"
                                                                   Visibility="{Binding RequiresConfirmation, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Entry.Description}" Foreground="Gray" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding ErrorMessage}" Foreground="IndianRed"
                                                               Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="0,0,20,0" VerticalAlignment="Top">
                                                    <ToggleButton Style="{StaticResource ToggleSwitchStyle}"
                                                                  HorizontalAlignment="Center"
                                                                  IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                                  ToolTip="{Binding StateLabel}"
                                                                  Click="OnToggleClicked" Tag="{Binding}"/>
                                                    <TextBlock Text="{Binding StateLabel}" Foreground="Gray" FontSize="10"
                                                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
