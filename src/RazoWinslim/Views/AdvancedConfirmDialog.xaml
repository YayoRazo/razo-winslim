<Window x:Class="RazoWinslim.Views.AdvancedConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm advanced change" Height="220" Width="420"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="16">
        <TextBlock x:Name="MessageText" TextWrapping="Wrap" Margin="0,0,0,12"/>
        <CheckBox x:Name="ConfirmCheckBox" Content="I understand this affects Windows security protection"
                  Checked="OnCheckedChanged" Unchecked="OnCheckedChanged"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Width="80" Margin="0,0,8,0" Click="OnCancel" IsCancel="True"/>
            <Button x:Name="ApplyButton" Content="Apply" Width="80" IsEnabled="False" Click="OnApply"/>
        </StackPanel>
    </StackPanel>
</Window>
